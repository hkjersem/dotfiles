#!/usr/bin/env bash

# Shortcuts
alias _="sudo"
alias g="git"
alias h="history"
alias rr="rm -rf"

# Default options
alias rsync="rsync -vh"

# Global aliases
alias G="| grep -i"
alias H="| head"
alias T="| tail"
alias L="| less"

# dir listing/traversal
alias l="ls -lahA"
alias la='ls -lAh'
alias ll="ls -lA"
alias lt="ls -lhAtr"
alias ld="ls -ld */"
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias -- -="cd -" # Go to previous dir with -
alias cd.='cd $(readlink -f .)' # Go to real dir (i.e. if current dir is linked)
alias tree="tree -A -C -L 2 --gitignore"
alias tree1="tree -d -L 1"
alias tree2="tree -d -L 2"
alias cpwd="pwd|tr -d '\n'|pbcopy" # Copies current path to clipboard

# npm
alias ni="npm install"
alias nun="npm uninstall"
alias nup="npm update && npm out"
alias nrr="find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
alias pn=pnpm
alias pnx='pnpm dlx'

# Network
alias ip="dig +short myip.opendns.com @resolver1.opendns.com"
alias localip="ipconfig getifaddr en0"

# Logs
alias systail='log stream --style syslog'

# Recursively remove Apple meta files
alias cleanupds="find . -type f -name '*.DS_Store' -ls -exec /bin/rm {} \;"
alias cleanupad="find . -type d -name '.AppleD*' -ls -exec /bin/rm -r {} \;"
alias cleanup="cleanupds && cleanupad"

# Miscellaneous
alias quit="exit"
alias week="date +%V"

# Enable aliases to be sudo’ed
alias sudo='sudo '

# Dotfiles management
alias dotfiles-update='bash ~/.dotfiles/macos/update.sh --no-defaults'
alias dotfiles-install='bash ~/.dotfiles/install --no-audit; bash ~/.dotfiles/macos/install.sh --no-defaults'
alias dotfiles-audit='bash ~/.dotfiles/scripts/audit.sh'

# Flush Directory Service cache
alias flush="dscacheutil -flushcache && killall -HUP mDNSResponder"

# Trim new lines and copy to clipboard
alias c="tr -d '\n' | pbcopy"

# Empty the Trash on all mounted volumes and the main HDD.
alias emptytrash="sudo rm -rfv /Volumes/*/.Trashes; sudo rm -rfv ~/.Trash"

# Clear Apple’s System Logs to improve shell startup speed. Clear download history from quarantine. https://mths.be/bum
alias clearlogs=" sudo rm -rfv /private/var/log/asl/*.asl; sqlite3 ~/Library/Preferences/com.apple.LaunchServices.QuarantineEventsV* 'delete from LSQuarantineEvent'"

# URL-encode strings
alias urlencode='python3 -c "import sys, urllib.parse; print(urllib.parse.quote_plus(sys.argv[1]));"'

# Lock the screen
alias afk="/System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend"

# Reload the shell
alias reload="exec $SHELL -l"

# Kill almost all of the running applications on the currently logged in user
alias rebootapps="launchctl reboot apps"

# Restart all user applications without rebooting the entire system
alias rebootuserspace="sudo launchctl reboot userspace"

# Print each PATH entry on a separate line
alias path='echo -e ${PATH//:/\\n}'

# Install a Node version via fnm and carry over global packages
# Usage: install_node [version]  e.g. install_node 20, install_node lts
install_node() { bash "$HOME/.dotfiles/scripts/install-node.sh" "$@"; }

# Diff global npm packages between two node versions
# Usage: npm_globals_diff <version_a> [version_b]  (version_b defaults to current node)
#   Versions can be a major (22), full string (v22.22.0), or lts
#   e.g. npm_globals_diff 22, npm_globals_diff lts 22
npm_globals_diff() { bash "$HOME/.dotfiles/scripts/npm-globals-diff.sh" "$@"; }

# Check days since release for an npm package (last 10 versions by default)
# Usage: npm_release_age <package>[@version] [--all|-a] [--date|-d] [--beta|-b]
#   e.g. npm_release_age react, npm_release_age react@19 --all, npm_release_age react@19.1.1
npm_release_age() { bash "$HOME/.dotfiles/scripts/npm-release-age.sh" "$@"; }

# Updates minor/patch only, skips major version bumps by default
# Usage: pn_update [--dry-run] [--yes] [--force] [--major] [--cooldown <days>] [<package>]
pn_update() { bash "$HOME/.dotfiles/scripts/pnpm-update.sh" "$@"; }

# Create a directory and cd into it
mkd() { mkdir -p "$@" && cd "$_"; }

# Open current directory (or given path) in Finder
o() { open "${1:-.}"; }

# Clone a git repo and cd into it: gclone <url> [name]
gclone() { git clone "$@" && cd "${2:-$(basename "${1%.git}")}"; }

# Serve current directory over HTTP: server [port] (default: 8080)
server() { python3 -m http.server "${1:-8080}"; }

# Prevent iCloud from syncing specific folders: nosync [folder...] (default: node_modules .git)
nosync() {
    [[ $# -eq 0 ]] && set -- "node_modules" ".git"
    for arg in "$@"; do
        mkdir -p "$arg"
        xattr -w 'com.apple.fileprovider.ignore#P' 1 "$arg"
    done
}
